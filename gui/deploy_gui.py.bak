# 标签页 1：数据处理
# ═══════════════════════════════════════════════════════════════
class DataTab(QWidget):
    def __init__(self, parent=None):
        super().__init__(parent)
        self.worker = None
        self._build()

    def _build(self):
        layout = QVBoxLayout(self)
        layout.setContentsMargins(16, 16, 16, 16)
        layout.setSpacing(12)

        # ── FLIR 数据集转换 ──
        g1 = QGroupBox("FLIR 数据集预处理 (COCO → YOLO)")
        gl1 = QGridLayout()
        gl1.setSpacing(10)
        gl1.addWidget(QLabel("原始数据目录:"), 0, 0)
        self.flir_input = QLineEdit("data/raw/flir")
        gl1.addWidget(self.flir_input, 0, 1)
        btn_browse1 = QPushButton("浏览…")
        btn_browse1.clicked.connect(
            lambda: self._browse_dir(self.flir_input))
        gl1.addWidget(btn_browse1, 0, 2)
        self.btn_prepare = QPushButton("▶ 处理 FLIR 数据集")
        self.btn_prepare.setObjectName("btnPrimary")
        self.btn_prepare.clicked.connect(self._run_prepare)
        gl1.addWidget(self.btn_prepare, 1, 0, 1, 3)
        g1.setLayout(gl1)
        layout.addWidget(g1)

        # ── 图像转视频 ──
        g2 = QGroupBox("图像序列 → 视频 (用于跟踪评估)")
        gl2 = QGridLayout()
        gl2.setSpacing(10)
        gl2.addWidget(QLabel("图像目录:"), 0, 0)
        self.img_input = QLineEdit()
        gl2.addWidget(self.img_input, 0, 1)
        btn_browse2 = QPushButton("浏览…")
        btn_browse2.clicked.connect(
            lambda: self._browse_dir(self.img_input))
        gl2.addWidget(btn_browse2, 0, 2)
        gl2.addWidget(QLabel("输出目录:"), 1, 0)
        self.vid_output = QLineEdit("data/videos/thermal_test")
        gl2.addWidget(self.vid_output, 1, 1, 1, 2)
        gl2.addWidget(QLabel("FPS:"), 2, 0)
        self.fps_spin = QSpinBox()
        self.fps_spin.setRange(1, 120)
        self.fps_spin.setValue(30)
        gl2.addWidget(self.fps_spin, 2, 1, 1, 2)
        self.btn_img2vid = QPushButton("▶ 转换为视频")
        self.btn_img2vid.setObjectName("btnPrimary")
        self.btn_img2vid.clicked.connect(self._run_img2vid)
        gl2.addWidget(self.btn_img2vid, 3, 0, 1, 3)
        g2.setLayout(gl2)
        layout.addWidget(g2)

        self.log = LogPanel()
        layout.addWidget(self.log, stretch=1)

    def _browse_dir(self, line_edit):
        d = QFileDialog.getExistingDirectory(self, "选择目录", str(ROOT))
        if d:
            line_edit.setText(d)

    def _run_cmd(self, cmd, btn):
        if self.worker and self.worker.isRunning():
            QMessageBox.warning(self, "忙", "上一个任务仍在运行")
            return
        self.log.clear_log()
        btn.setEnabled(False)
        self.worker = LocalCmdWorker(cmd)
        self.worker.log_line.connect(self.log.append_log)
        self.worker.finished.connect(lambda _: btn.setEnabled(True))
        self.worker.start()

    def _run_prepare(self):
        cmd = (f'python scripts/data/prepare_flir.py '
               f'--input "{self.flir_input.text()}"')
        self._run_cmd(cmd, self.btn_prepare)

    def _run_img2vid(self):
        cmd = (f'python scripts/data/images_to_video.py '
               f'--input "{self.img_input.text()}" '
               f'--output "{self.vid_output.text()}" '
               f'--fps {self.fps_spin.value()}')
        self._run_cmd(cmd, self.btn_img2vid)



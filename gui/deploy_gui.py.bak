# ═══════════════════════════════════════════════════════════════
# 工具函数
# ═══════════════════════════════════════════════════════════════
def find_weights():
    """扫描消融实验目录，返回 [(显示名, 路径), ...]"""
    results = []
    if ABLATION_DIR.is_dir():
        for exp in sorted(ABLATION_DIR.iterdir()):
            pt = exp / "weights" / "best.pt"
            if pt.exists():
                results.append((exp.name, str(pt)))
    return results


def find_result_videos():
    """扫描板端结果和跟踪结果中的 mp4 文件"""
    videos = []
    for d in [BOARD_RESULTS_DIR, TRACKING_RESULTS_DIR]:
        if d.is_dir():
            for mp4 in sorted(d.rglob("*.mp4")):
                rel = mp4.relative_to(ROOT)
                videos.append((str(rel), str(mp4)))
    return videos


def find_result_images():
    """扫描板端结果和检测结果中的 png 文件"""
    images = []
    for d in [BOARD_RESULTS_DIR, DETECTION_RESULTS_DIR,
              ROOT / "outputs" / "results"]:
        if d.is_dir():
            for img in sorted(d.rglob("*.png")):
                rel = img.relative_to(ROOT)
                images.append((str(rel), str(img)))
    return images


def dpi_scale(app):
    """计算 DPI 缩放因子"""
    screen = app.primaryScreen()
    if screen:
        dpi = screen.logicalDotsPerInch()
        return max(1.0, dpi / 96.0)
    return 1.0


# ═══════════════════════════════════════════════════════════════
# 后台工作线程
# ═══════════════════════════════════════════════════════════════
class LocalCmdWorker(QThread):
    """本地 Python 命令执行线程"""
    log_line = pyqtSignal(str, str)  # (text, level)
    finished = pyqtSignal(int)

    def __init__(self, cmd, cwd=None, parent=None):
        super().__init__(parent)
        self.cmd = cmd
        self.cwd = cwd or str(ROOT)

    def run(self):
        try:
            self.log_line.emit(f"$ {self.cmd}", "cmd")
            proc = subprocess.Popen(
                self.cmd, shell=True, stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT, text=True,
                cwd=self.cwd, encoding="utf-8", errors="replace",
            )
            for line in iter(proc.stdout.readline, ""):
                line = line.rstrip("\n\r")
                if line:
                    self.log_line.emit(line, "info")
            proc.wait()
            code = proc.returncode
            if code == 0:
                self.log_line.emit("✓ 完成 (退出码 0)", "ok")
            else:
                self.log_line.emit(f"✗ 错误 (退出码 {code})", "err")
            self.finished.emit(code)
        except Exception as e:
            self.log_line.emit(f"✗ 异常: {e}", "err")
            self.finished.emit(-1)


class SSHWorker(QThread):
    """SSH → ADB 远程命令执行线程"""
    log_line = pyqtSignal(str, str)
    finished = pyqtSignal(int)

    def __init__(self, cmd, parent=None):
        super().__init__(parent)
        self.cmd = cmd

    def run(self):
        try:
            ssh = paramiko.SSHClient()
            ssh.set_missing_host_key_policy(paramiko.AutoAddPolicy())
            ssh.connect(UBUNTU_HOST, username=UBUNTU_USER,
                        password=UBUNTU_PASS, timeout=10)
            self.log_line.emit(f"[SSH] 已连接 {UBUNTU_HOST}", "ok")
            self.log_line.emit(f"$ {self.cmd}", "cmd")

            _, stdout, stderr = ssh.exec_command(self.cmd, get_pty=True,
                                                  timeout=600)
            for raw in iter(stdout.readline, ""):
                line = raw.rstrip("\n\r")
                if not line:
                    continue
                lvl = "info"
                if "error" in line.lower() or "fail" in line.lower():
                    lvl = "err"
                elif "done" in line.lower() or "完成" in line or "ok" in line.lower():
                    lvl = "ok"
                self.log_line.emit(line, lvl)

            err = stderr.read().decode(errors="replace").strip()
            if err:
                for el in err.splitlines():
                    self.log_line.emit(el, "err")
            ssh.close()
            self.log_line.emit("✓ SSH 会话结束", "ok")
            self.finished.emit(0)
        except Exception as e:
            self.log_line.emit(f"✗ SSH 错误: {e}", "err")
            self.finished.emit(-1)


class SCPDownloadWorker(QThread):
    """通过 SSH+SFTP 从 Ubuntu 拉取板端文件到本地"""
    log_line = pyqtSignal(str, str)
    progress = pyqtSignal(int)
    finished = pyqtSignal(int, str)  # (code, local_path)

    def __init__(self, remote_path, local_path, parent=None):
        super().__init__(parent)
        self.remote_path = remote_path
        self.local_path = local_path

    def run(self):
        try:
            ssh = paramiko.SSHClient()
            ssh.set_missing_host_key_policy(paramiko.AutoAddPolicy())
            ssh.connect(UBUNTU_HOST, username=UBUNTU_USER,
                        password=UBUNTU_PASS, timeout=10)
            self.log_line.emit(f"[SFTP] 下载 {self.remote_path}", "cmd")

            # 先从板端 adb pull 到 Ubuntu /tmp
            ubuntu_tmp = f"/tmp/board_pull_{os.getpid()}"
            adb_cmd = (f"adb -s {ADB_SERIAL} pull "
                       f"{self.remote_path} {ubuntu_tmp}")
            _, out, err = ssh.exec_command(adb_cmd, timeout=120)
            result = out.read().decode(errors="replace")
            self.log_line.emit(result.strip(), "info")

            # 再 SFTP 下载到本地
            sftp = ssh.open_sftp()
            os.makedirs(os.path.dirname(self.local_path), exist_ok=True)
            sftp.get(ubuntu_tmp, self.local_path)
            sftp.close()

            # 清理
            ssh.exec_command(f"rm -f {ubuntu_tmp}")
            ssh.close()
            self.log_line.emit(f"✓ 已下载到 {self.local_path}", "ok")
            self.finished.emit(0, self.local_path)
        except Exception as e:
            self.log_line.emit(f"✗ 下载失败: {e}", "err")
            self.finished.emit(-1, "")


# ═══════════════════════════════════════════════════════════════
# 日志面板
# ═══════════════════════════════════════════════════════════════
class LogPanel(QTextEdit):
    COLORS = {
        "info": "#2c3e50",
        "cmd":  "#1565c0",
        "ok":   "#2e7d32",
        "err":  "#c62828",
        "warn": "#e65100",
    }

    def __init__(self, parent=None):
        super().__init__(parent)
        self.setReadOnly(True)
        self.setMinimumHeight(120)

    def append_log(self, text, level="info"):
        color = self.COLORS.get(level, "#2c3e50")
        self.append(f'<span style="color:{color};font-size:13px">{text}</span>')
        sb = self.verticalScrollBar()
        sb.setValue(sb.maximum())

    def clear_log(self):
        self.clear()


# ═══════════════════════════════════════════════════════════════
# 视频播放器组件
# ═══════════════════════════════════════════════════════════════
class VideoPlayer(QWidget):
    """基于 OpenCV 的轻量视频播放器"""

    def __init__(self, parent=None):
        super().__init__(parent)
        self.cap = None
        self.timer = QTimer(self)
        self.timer.timeout.connect(self._next_frame)
        self.playing = False
        self.total_frames = 0
        self.current_frame = 0
        self._build()

    def _build(self):
        layout = QVBoxLayout(self)
        layout.setContentsMargins(0, 0, 0, 0)
        layout.setSpacing(4)

        # 视频显示区域
        self.display = QLabel()
        self.display.setAlignment(Qt.AlignCenter)
        self.display.setMinimumSize(320, 240)
        self.display.setSizePolicy(QSizePolicy.Expanding, QSizePolicy.Expanding)
        self.display.setStyleSheet(
            "background: #1a1a2e; border-radius: 6px; color: #888;")
        self.display.setText("无视频\n选择文件或运行检测后查看结果")
        layout.addWidget(self.display, stretch=1)

        # 进度条
        self.slider = QSlider(Qt.Horizontal)
        self.slider.setMinimum(0)
        self.slider.sliderMoved.connect(self._seek)
        layout.addWidget(self.slider)

        # 控制栏
        ctrl = QHBoxLayout()
        self.btn_open = QPushButton("📂 打开")
        self.btn_open.clicked.connect(self._open_file)
        self.btn_play = QPushButton("▶")
        self.btn_play.clicked.connect(self._toggle_play)
        self.btn_stop = QPushButton("⏹")
        self.btn_stop.clicked.connect(self._stop)
        self.lbl_time = QLabel("0 / 0")
        self.lbl_fps = QLabel("")

        ctrl.addWidget(self.btn_open)
        ctrl.addWidget(self.btn_play)
        ctrl.addWidget(self.btn_stop)
        ctrl.addWidget(self.lbl_time)
        ctrl.addStretch()
        ctrl.addWidget(self.lbl_fps)
        layout.addLayout(ctrl)

    def load_video(self, path):
        self._stop()
        if self.cap:
            self.cap.release()
        self.cap = cv2.VideoCapture(path)
        if not self.cap.isOpened():
            self.display.setText(f"无法打开: {path}")
            return
        self.total_frames = int(self.cap.get(cv2.CAP_PROP_FRAME_COUNT))
        fps = self.cap.get(cv2.CAP_PROP_FPS) or 30
        self.interval = int(1000 / fps)
        self.slider.setMaximum(max(0, self.total_frames - 1))
        self.current_frame = 0
        self.lbl_fps.setText(f"{fps:.0f} FPS")
        self._show_frame(0)

    def load_image(self, path):
        self._stop()
        if self.cap:
            self.cap.release()
            self.cap = None
        pixmap = QPixmap(path)
        if pixmap.isNull():
            self.display.setText(f"无法打开: {path}")
            return
        scaled = pixmap.scaled(self.display.size(),
                               Qt.KeepAspectRatio, Qt.SmoothTransformation)
        self.display.setPixmap(scaled)
        self.lbl_time.setText("图片")
        self.slider.setMaximum(0)

    def _open_file(self):
        path, _ = QFileDialog.getOpenFileName(
            self, "打开视频或图片",
            str(ROOT / "outputs"),
            "媒体文件 (*.mp4 *.avi *.png *.jpg);;所有文件 (*)")
        if path:
            if path.lower().endswith(('.mp4', '.avi', '.mkv')):
                self.load_video(path)
            else:
                self.load_image(path)

    def _toggle_play(self):
        if not self.cap:
            return
        if self.playing:
            self.timer.stop()
            self.playing = False
            self.btn_play.setText("▶")
        else:
            self.timer.start(self.interval)
            self.playing = True
            self.btn_play.setText("⏸")

    def _stop(self):
        self.timer.stop()
        self.playing = False
        self.btn_play.setText("▶")
        self.current_frame = 0
        if self.cap:
            self.cap.set(cv2.CAP_PROP_POS_FRAMES, 0)
            self._show_frame(0)

    def _seek(self, pos):
        if self.cap:
            self.cap.set(cv2.CAP_PROP_POS_FRAMES, pos)
            self.current_frame = pos
            self._read_and_show()

    def _next_frame(self):
        if not self.cap:
            return
        self.current_frame += 1
        if self.current_frame >= self.total_frames:
            self._stop()
            return
        self._read_and_show()

    def _show_frame(self, idx):
        if self.cap:
            self.cap.set(cv2.CAP_PROP_POS_FRAMES, idx)
            self._read_and_show()

    def _read_and_show(self):
        ret, frame = self.cap.read()
        if not ret:
            self._stop()
            return
        rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
        h, w, ch = rgb.shape
        qimg = QImage(rgb.data, w, h, ch * w, QImage.Format_RGB888)
        pixmap = QPixmap.fromImage(qimg)
        scaled = pixmap.scaled(self.display.size(),
                               Qt.KeepAspectRatio, Qt.SmoothTransformation)
        self.display.setPixmap(scaled)
        self.slider.setValue(self.current_frame)
        self.lbl_time.setText(f"{self.current_frame} / {self.total_frames}")



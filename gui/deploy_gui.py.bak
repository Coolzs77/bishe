# 标签页 3：检测评估
# ═══════════════════════════════════════════════════════════════
class DetectionTab(QWidget):
    def __init__(self, parent=None):
        super().__init__(parent)
        self.worker = None
        self._build()

    def _build(self):
        layout = QVBoxLayout(self)
        layout.setContentsMargins(16, 16, 16, 16)
        layout.setSpacing(12)

        # ── 检测评估 ──
        g1 = QGroupBox("检测指标 / 速度评估")
        pg = QGridLayout()
        pg.setSpacing(10)

        pg.addWidget(QLabel("模式:"), 0, 0)
        self.mode_combo = QComboBox()
        self.mode_combo.addItem("metric — P/R/mAP 指标", "metric")
        self.mode_combo.addItem("speed — 推理速度测试", "speed")
        pg.addWidget(self.mode_combo, 0, 1, 1, 2)

        pg.addWidget(QLabel("权重:"), 1, 0)
        self.weights_combo = QComboBox()
        self.weights_combo.setSizePolicy(QSizePolicy.Expanding,
                                         QSizePolicy.Fixed)
        for name, path in find_weights():
            self.weights_combo.addItem(name, path)
        pg.addWidget(self.weights_combo, 1, 1)
        btn_browse = QPushButton("浏览…")
        btn_browse.setMaximumWidth(80)
        btn_browse.clicked.connect(self._browse_weights)
        pg.addWidget(btn_browse, 1, 2)

        pg.addWidget(QLabel("Conf 阈值:"), 2, 0)
        self.conf_spin = QDoubleSpinBox()
        self.conf_spin.setRange(0.001, 1.0)
        self.conf_spin.setValue(0.001)
        self.conf_spin.setSingleStep(0.01)
        self.conf_spin.setDecimals(3)
        pg.addWidget(self.conf_spin, 2, 1, 1, 2)

        pg.addWidget(QLabel("IoU 阈值:"), 3, 0)
        self.iou_spin = QDoubleSpinBox()
        self.iou_spin.setRange(0.1, 1.0)
        self.iou_spin.setValue(0.6)
        self.iou_spin.setSingleStep(0.05)
        pg.addWidget(self.iou_spin, 3, 1, 1, 2)

        pg.addWidget(QLabel("图像尺寸:"), 4, 0)
        self.imgsz_spin = QSpinBox()
        self.imgsz_spin.setRange(320, 1280)
        self.imgsz_spin.setValue(640)
        self.imgsz_spin.setSingleStep(32)
        pg.addWidget(self.imgsz_spin, 4, 1, 1, 2)

        pg.addWidget(QLabel("Batch:"), 5, 0)
        self.batch_spin = QSpinBox()
        self.batch_spin.setRange(1, 128)
        self.batch_spin.setValue(32)
        pg.addWidget(self.batch_spin, 5, 1, 1, 2)

        chk = QHBoxLayout()
        self.chk_batch = QCheckBox("批量评估全部消融实验")
        chk.addWidget(self.chk_batch)
        chk.addStretch()
        pg.addLayout(chk, 6, 0, 1, 3)

        g1.setLayout(pg)
        layout.addWidget(g1)

        # 操作栏
        btn_row = QHBoxLayout()
        self.btn_eval = QPushButton("▶ 运行检测评估")
        self.btn_eval.setObjectName("btnPrimary")
        self.btn_eval.clicked.connect(self._run_eval)
        self.btn_efficiency = QPushButton("▶ 模型效率评估")
        self.btn_efficiency.setObjectName("btnSecondary")
        self.btn_efficiency.clicked.connect(self._run_efficiency)
        self.btn_plot = QPushButton("📊 生成评估图表")
        self.btn_plot.setObjectName("btnSecondary")
        self.btn_plot.clicked.connect(self._run_plot)
        btn_row.addWidget(self.btn_eval)
        btn_row.addWidget(self.btn_efficiency)
        btn_row.addWidget(self.btn_plot)
        btn_row.addStretch()
        layout.addLayout(btn_row)

        self.log = LogPanel()
        layout.addWidget(self.log, stretch=1)

    def _browse_weights(self):
        path, _ = QFileDialog.getOpenFileName(
            self, "选择权重", str(ROOT / "outputs"), "PyTorch (*.pt)")
        if path:
            self.weights_combo.addItem(Path(path).stem, path)
            self.weights_combo.setCurrentIndex(
                self.weights_combo.count() - 1)

    def _run_cmd(self, cmd, btn):
        if self.worker and self.worker.isRunning():
            QMessageBox.warning(self, "忙", "上一个任务仍在运行")
            return
        self.log.clear_log()
        btn.setEnabled(False)
        self.worker = LocalCmdWorker(cmd)
        self.worker.log_line.connect(self.log.append_log)
        self.worker.finished.connect(lambda _: btn.setEnabled(True))
        self.worker.start()

    def _run_eval(self):
        weights = self.weights_combo.currentData()
        if not weights and not self.chk_batch.isChecked():
            QMessageBox.warning(self, "缺少权重", "请先选择模型权重文件")
            return
        cmd = (f'python scripts/evaluate/eval_detection.py '
               f'--config configs/eval_detection.yaml '
               f'--mode {self.mode_combo.currentData()} '
               f'--conf-thres {self.conf_spin.value()} '
               f'--iou-thres {self.iou_spin.value()} '
               f'--img-size {self.imgsz_spin.value()} '
               f'--batch-size {self.batch_spin.value()}')
        if weights and not self.chk_batch.isChecked():
            cmd += f' --weights "{weights}"'
        if self.chk_batch.isChecked():
            cmd += ' --batch-eval'
        self._run_cmd(cmd, self.btn_eval)

    def _run_efficiency(self):
        cmd = 'python scripts/evaluate/eval_model_efficiency.py'
        self._run_cmd(cmd, self.btn_efficiency)

    def _run_plot(self):
        cmd = ('python scripts/evaluate/plot_eval_summary.py '
               '--config configs/plot_eval_summary.yaml')
        self._run_cmd(cmd, self.btn_plot)


# ═══════════════════════════════════════════════════════════════
# 标签页 4：跟踪评估
# ═══════════════════════════════════════════════════════════════
class TrackingTab(QWidget):
    def __init__(self, parent=None):
        super().__init__(parent)
        self.worker = None
        self._build()

    def _build(self):
        layout = QVBoxLayout(self)
        layout.setContentsMargins(16, 16, 16, 16)
        layout.setSpacing(12)

        g1 = QGroupBox("跟踪评估参数")
        pg = QGridLayout()
        pg.setSpacing(10)

        pg.addWidget(QLabel("权重:"), 0, 0)
        self.weights_combo = QComboBox()
        self.weights_combo.setSizePolicy(QSizePolicy.Expanding,
                                         QSizePolicy.Fixed)
        for name, path in find_weights():
            self.weights_combo.addItem(name, path)
        pg.addWidget(self.weights_combo, 0, 1)
        btn_browse = QPushButton("浏览…")
        btn_browse.setMaximumWidth(80)
        btn_browse.clicked.connect(self._browse_weights)
        pg.addWidget(btn_browse, 0, 2)

        pg.addWidget(QLabel("跟踪器:"), 1, 0)
        self.tracker_combo = QComboBox()
        for t in TRACKERS:
            self.tracker_combo.addItem(t)
        pg.addWidget(self.tracker_combo, 1, 1, 1, 2)

        pg.addWidget(QLabel("数据源:"), 2, 0)
        self.data_edit = QLineEdit("data/videos/thermal_test")
        pg.addWidget(self.data_edit, 2, 1)
        btn_data = QPushButton("浏览…")
        btn_data.setMaximumWidth(80)
        btn_data.clicked.connect(self._browse_data)
        pg.addWidget(btn_data, 2, 2)

        pg.addWidget(QLabel("Conf 阈值:"), 3, 0)
        self.conf_spin = QDoubleSpinBox()
        self.conf_spin.setRange(0.01, 1.0)
        self.conf_spin.setValue(0.25)
        self.conf_spin.setSingleStep(0.05)
        pg.addWidget(self.conf_spin, 3, 1, 1, 2)

        pg.addWidget(QLabel("NMS 阈值:"), 4, 0)
        self.nms_spin = QDoubleSpinBox()
        self.nms_spin.setRange(0.1, 1.0)
        self.nms_spin.setValue(0.45)
        self.nms_spin.setSingleStep(0.05)
        pg.addWidget(self.nms_spin, 4, 1, 1, 2)

        pg.addWidget(QLabel("图像尺寸:"), 5, 0)
        self.imgsz_spin = QSpinBox()
        self.imgsz_spin.setRange(320, 1280)
        self.imgsz_spin.setValue(640)
        self.imgsz_spin.setSingleStep(32)
        pg.addWidget(self.imgsz_spin, 5, 1, 1, 2)

        pg.addWidget(QLabel("输出目录:"), 6, 0)
        self.output_edit = QLineEdit("outputs/tracking/current")
        pg.addWidget(self.output_edit, 6, 1, 1, 2)

        chk_row = QHBoxLayout()
        self.chk_half = QCheckBox("FP16 半精度")
        self.chk_half.setChecked(True)
        self.chk_save_vid = QCheckBox("保存视频")
        self.chk_save_txt = QCheckBox("保存 MOT txt")
        self.chk_overlay = QCheckBox("绘制框")
        self.chk_overlay.setChecked(True)
        chk_row.addWidget(self.chk_half)
        chk_row.addWidget(self.chk_save_vid)
        chk_row.addWidget(self.chk_save_txt)
        chk_row.addWidget(self.chk_overlay)
        chk_row.addStretch()
        pg.addLayout(chk_row, 7, 0, 1, 3)

        g1.setLayout(pg)
        layout.addWidget(g1)

        btn_row = QHBoxLayout()
        self.btn_run = QPushButton("▶ 运行跟踪评估")
        self.btn_run.setObjectName("btnPrimary")
        self.btn_run.clicked.connect(self._run)
        self.btn_plot = QPushButton("📊 跟踪对比图表")
        self.btn_plot.setObjectName("btnSecondary")
        self.btn_plot.clicked.connect(self._run_plot)
        btn_row.addWidget(self.btn_run)
        btn_row.addWidget(self.btn_plot)
        btn_row.addStretch()
        layout.addLayout(btn_row)

        self.log = LogPanel()
        layout.addWidget(self.log, stretch=1)

    def _browse_weights(self):
        path, _ = QFileDialog.getOpenFileName(
            self, "选择权重", str(ROOT / "outputs"), "PyTorch (*.pt)")
        if path:
            self.weights_combo.addItem(Path(path).stem, path)
            self.weights_combo.setCurrentIndex(
                self.weights_combo.count() - 1)

    def _browse_data(self):
        d = QFileDialog.getExistingDirectory(self, "选择视频目录",
                                              str(ROOT / "data"))
        if d:
            self.data_edit.setText(d)

    def _run_cmd(self, cmd, btn):
        if self.worker and self.worker.isRunning():
            QMessageBox.warning(self, "忙", "上一个任务仍在运行")
            return
        self.log.clear_log()
        btn.setEnabled(False)
        self.worker = LocalCmdWorker(cmd)
        self.worker.log_line.connect(self.log.append_log)
        self.worker.finished.connect(lambda _: btn.setEnabled(True))
        self.worker.start()

    def _run(self):
        weights = self.weights_combo.currentData()
        if not weights:
            QMessageBox.warning(self, "缺少权重", "请先选择模型权重文件")
            return
        cmd = (f'python scripts/evaluate/eval_tracking.py '
               f'--config configs/tracking_config.yaml '
               f'--weights "{weights}" '
               f'--tracker {self.tracker_combo.currentText()} '
               f'--data "{self.data_edit.text()}" '
               f'--conf-thres {self.conf_spin.value()} '
               f'--nms-thres {self.nms_spin.value()} '
               f'--img-size {self.imgsz_spin.value()} '
               f'--output "{self.output_edit.text()}"')
        if self.chk_half.isChecked():
            cmd += ' --half'
        if not self.chk_save_vid.isChecked():
            cmd += ' --no-save-vid'
        if not self.chk_save_txt.isChecked():
            cmd += ' --no-save-txt'
        if not self.chk_overlay.isChecked():
            cmd += ' --no-overlay'
        self._run_cmd(cmd, self.btn_run)

    def _run_plot(self):
        cmd = ('python scripts/evaluate/'
               'plot_tracking_algorithm_comparison.py '
               '--config configs/plot_tracking_comparison.yaml')
        self._run_cmd(cmd, self.btn_plot)


# ═══════════════════════════════════════════════════════════════
# 标签页 5：板端部署
# ═══════════════════════════════════════════════════════════════
class DeployTab(QWidget):
    def __init__(self, parent=None):
        super().__init__(parent)
        self.worker = None
        self._build()

    def _build(self):
        main_split = QSplitter(Qt.Horizontal)
        main_split.setHandleWidth(6)

        # ── 左侧：操作面板 ──
        left = QWidget()
        left_layout = QVBoxLayout(left)
        left_layout.setContentsMargins(16, 16, 8, 16)
        left_layout.setSpacing(10)

        # 连接状态
        status_group = QGroupBox("板端连接")
        sl = QHBoxLayout()
        self.lbl_board = QLabel("Board: —")
        self.lbl_npu = QLabel("NPU: —")
        btn_check = QPushButton("🔄 刷新")
        btn_check.clicked.connect(self._check_status)
        sl.addWidget(self.lbl_board)
        sl.addWidget(self.lbl_npu)
        sl.addStretch()
        sl.addWidget(btn_check)
        status_group.setLayout(sl)
        left_layout.addWidget(status_group)

        # 参数
        param_group = QGroupBox("检测参数")
        pg = QGridLayout()
        pg.setSpacing(10)

        pg.addWidget(QLabel("模型:"), 0, 0)
        self.model_combo = QComboBox()
        for name, key in BOARD_MODELS:
            self.model_combo.addItem(f"{name}  ({key})", key)
        pg.addWidget(self.model_combo, 0, 1, 1, 2)

        pg.addWidget(QLabel("视频:"), 1, 0)
        self.video_combo = QComboBox()
        for label, val in BOARD_VIDEOS:
            self.video_combo.addItem(label, val)
        pg.addWidget(self.video_combo, 1, 1, 1, 2)

        pg.addWidget(QLabel("Conf:"), 2, 0)
        self.conf_edit = QLineEdit()
        self.conf_edit.setPlaceholderText("auto (默认 0.55)")
        pg.addWidget(self.conf_edit, 2, 1, 1, 2)

        pg.addWidget(QLabel("NMS:"), 3, 0)
        self.nms_edit = QLineEdit()
        self.nms_edit.setPlaceholderText("auto (默认 0.35)")
        pg.addWidget(self.nms_edit, 3, 1, 1, 2)

        self.chk_track = QCheckBox("启用时序对齐跟踪")
        self.chk_track.setChecked(True)
        pg.addWidget(self.chk_track, 4, 0, 1, 3)

        param_group.setLayout(pg)
        left_layout.addWidget(param_group)

        # 操作按钮
        btn_group = QGroupBox("操作")
        bg = QVBoxLayout()
        btn_row1 = QHBoxLayout()
        self.btn_img = QPushButton("▶ 图片检测")
        self.btn_img.setObjectName("btnPrimary")
        self.btn_img.clicked.connect(self._run_image)
        self.btn_vid = QPushButton("▶ 视频检测")
        self.btn_vid.setObjectName("btnPrimary")
        self.btn_vid.clicked.connect(self._run_video)
        btn_row1.addWidget(self.btn_img)
        btn_row1.addWidget(self.btn_vid)
        bg.addLayout(btn_row1)

        btn_row2 = QHBoxLayout()
        self.btn_pull_vid = QPushButton("⬇ 拉取输出视频")
        self.btn_pull_vid.setObjectName("btnSecondary")
        self.btn_pull_vid.clicked.connect(self._pull_and_play_video)
        self.btn_pull_img = QPushButton("⬇ 拉取输出图片")
        self.btn_pull_img.setObjectName("btnSecondary")
        self.btn_pull_img.clicked.connect(self._pull_images)
        btn_row2.addWidget(self.btn_pull_vid)
        btn_row2.addWidget(self.btn_pull_img)
        bg.addLayout(btn_row2)

        btn_row3 = QHBoxLayout()
        self.btn_mmse_status = QPushButton("🔍 查看 mmse 转换进度")
        self.btn_mmse_status.setObjectName("btnSecondary")
        self.btn_mmse_status.clicked.connect(self._check_mmse)
        self.btn_push = QPushButton("⬆ 推送 mmse 模型到板端")
        self.btn_push.setObjectName("btnSecondary")
        self.btn_push.clicked.connect(self._push_mmse)
        btn_row3.addWidget(self.btn_mmse_status)
        btn_row3.addWidget(self.btn_push)
        bg.addLayout(btn_row3)

        btn_group.setLayout(bg)
        left_layout.addWidget(btn_group)

        # NPU 指标卡片
        metrics_group = QGroupBox("运行指标")
        ml = QGridLayout()
        ml.setSpacing(8)
        self.m_npu = QLabel("NPU 延迟\n—")
        self.m_npu.setObjectName("metricCard")
        self.m_npu.setAlignment(Qt.AlignCenter)
        self.m_nfps = QLabel("NPU FPS\n—")
        self.m_nfps.setObjectName("metricCard")
        self.m_nfps.setAlignment(Qt.AlignCenter)
        self.m_efps = QLabel("E2E FPS\n—")
        self.m_efps.setObjectName("metricCard")
        self.m_efps.setAlignment(Qt.AlignCenter)
        self.m_det = QLabel("检测数\n—")
        self.m_det.setObjectName("metricCard")
        self.m_det.setAlignment(Qt.AlignCenter)
        ml.addWidget(self.m_npu, 0, 0)
        ml.addWidget(self.m_nfps, 0, 1)
        ml.addWidget(self.m_efps, 0, 2)
        ml.addWidget(self.m_det, 0, 3)
        metrics_group.setLayout(ml)
        left_layout.addWidget(metrics_group)

        # 日志
        self.log = LogPanel()
        left_layout.addWidget(self.log, stretch=1)

        # ── 右侧：视频/图片播放器 ──
        right = QWidget()
        right_layout = QVBoxLayout(right)
        right_layout.setContentsMargins(8, 16, 16, 16)

        rlbl = QLabel("结果预览")
        rlbl.setObjectName("sectionTitle")
        right_layout.addWidget(rlbl)

        self.player = VideoPlayer()
        right_layout.addWidget(self.player, stretch=1)

        # 结果文件列表
        result_group = QGroupBox("已有结果文件")
        rg = QVBoxLayout()
        self.result_combo = QComboBox()
        self._refresh_results()
        rg.addWidget(self.result_combo)
        btn_view = QPushButton("📺 查看选中结果")
        btn_view.clicked.connect(self._view_selected_result)
        rg.addWidget(btn_view)
        btn_refresh = QPushButton("🔄 刷新列表")
        btn_refresh.clicked.connect(self._refresh_results)
        rg.addWidget(btn_refresh)
        result_group.setLayout(rg)
        right_layout.addWidget(result_group)

        main_split.addWidget(left)
        main_split.addWidget(right)
        main_split.setSizes([500, 500])

        outer = QHBoxLayout(self)
        outer.setContentsMargins(0, 0, 0, 0)
        outer.addWidget(main_split)

    def _refresh_results(self):
        self.result_combo.clear()
        for label, path in find_result_videos():
            self.result_combo.addItem(f"🎬 {label}", path)
        for label, path in find_result_images():
            self.result_combo.addItem(f"🖼 {label}", path)

    def _view_selected_result(self):
        path = self.result_combo.currentData()
        if not path:
            return
        if path.lower().endswith(('.mp4', '.avi')):
            self.player.load_video(path)
        else:
            self.player.load_image(path)

    def _adb_cmd(self, board_cmd):
        return (f'adb -s {ADB_SERIAL} shell '
                f'"cd {BOARD_DEPLOY} && '
                f'export LD_LIBRARY_PATH=./lib && {board_cmd}"')

    def _ssh_run(self, cmd):
        if self.worker and self.worker.isRunning():
            QMessageBox.warning(self, "忙", "上一个任务仍在运行")
            return
        self.log.clear_log()
        self._set_buttons(False)
        self.worker = SSHWorker(cmd)
        self.worker.log_line.connect(self._on_log)
        self.worker.finished.connect(self._on_done)
        self.worker.start()

    def _set_buttons(self, enabled):
        for btn in [self.btn_img, self.btn_vid, self.btn_pull_vid,
                     self.btn_pull_img, self.btn_push, self.btn_mmse_status]:
            btn.setEnabled(enabled)

    def _on_log(self, text, level):
        self.log.append_log(text, level)
        self._parse_metrics(text)

    def _on_done(self, code):
        self._set_buttons(True)

    def _parse_metrics(self, text):
        m = re.search(r'NPU[:\s]+(\d+\.?\d*)\s*ms', text, re.I)
        if not m:
            m = re.search(r'NPU\s+latency[:\s]+(\d+\.?\d*)', text, re.I)
        if m:
            val = float(m.group(1))
            color = ("#2e7d32" if val <= 25
                     else "#e65100" if val <= 35
                     else "#c62828")
            self.m_npu.setText(f"NPU 延迟\n{val:.1f} ms")
            self.m_npu.setStyleSheet(
                f"color: {color}; font-weight: bold; font-size: 16px;")

        m = re.search(r'NPU\s*FPS[:\s]+(\d+\.?\d*)', text, re.I)
        if m:
            self.m_nfps.setText(f"NPU FPS\n{float(m.group(1)):.1f}")
        m = re.search(r'E2E\s*FPS[:\s]+(\d+\.?\d*)', text, re.I)
        if m:
            self.m_efps.setText(f"E2E FPS\n{float(m.group(1)):.1f}")
        m = re.search(r'(?:total|Detections)[:\s]+(\d+)', text, re.I)
        if m:
            self.m_det.setText(f"检测数\n{m.group(1)}")

    def _run_image(self):
        model = self.model_combo.currentData()
        self._ssh_run(self._adb_cmd(f"./bishe_rknn_detect model/{model}"))

    def _run_video(self):
        model = self.model_combo.currentData()
        video = self.video_combo.currentData()
        track = "1" if self.chk_track.isChecked() else "0"
        conf = self.conf_edit.text().strip() or "0.55"
        nms = self.nms_edit.text().strip() or "0.35"
        board_cmd = (f"./bishe_rknn_video model/{model} model/{video} "
                     f"model/infrared_labels.txt /dev/null {conf} {nms} "
                     f"{track}")
        self._ssh_run(self._adb_cmd(board_cmd))

    def _pull_and_play_video(self):
        """从板端拉取最新输出视频并自动播放"""
        model = self.model_combo.currentData()
        model_stem = Path(model).stem
        video = self.video_combo.currentData()
        video_stem = Path(video).stem
        remote = f"{BOARD_DEPLOY}/outputs/out_{model_stem}_{video_stem}.mp4"
        local = str(BOARD_RESULTS_DIR
                     / f"out_{model_stem}_{video_stem}.mp4")

        if self.worker and self.worker.isRunning():
            QMessageBox.warning(self, "忙", "上一个任务仍在运行")
            return

        self.log.clear_log()
        self._set_buttons(False)

        # 先 adb pull 到 Ubuntu /tmp，再 sftp 到本地
        pull_cmd = (
            f'adb -s {ADB_SERIAL} pull {remote} /tmp/board_pull_video.mp4 '
            f'&& echo PULL_OK')
        self.worker = SSHWorker(pull_cmd)
        self.worker.log_line.connect(self._on_log)

        def _on_pull_done(code):
            self._set_buttons(True)
            if code == 0:
                # 用 sftp 下载
                self._sftp_download("/tmp/board_pull_video.mp4", local)

        self.worker.finished.connect(_on_pull_done)
        self.worker.start()

    def _sftp_download(self, remote, local):
        def _do():
            try:
                ssh = paramiko.SSHClient()
                ssh.set_missing_host_key_policy(paramiko.AutoAddPolicy())
                ssh.connect(UBUNTU_HOST, username=UBUNTU_USER,
                            password=UBUNTU_PASS, timeout=10)
                sftp = ssh.open_sftp()
                os.makedirs(os.path.dirname(local), exist_ok=True)
                sftp.get(remote, local)
                sftp.close()
                ssh.close()
                self.log.append_log(f"✓ 已下载到 {local}", "ok")
                # 自动播放
                self.player.load_video(local)
                self._refresh_results()
            except Exception as e:
                self.log.append_log(f"✗ SFTP 下载失败: {e}", "err")

        threading.Thread(target=_do, daemon=True).start()

    def _pull_images(self):
        cmd = (f'adb -s {ADB_SERIAL} pull '
               f'{BOARD_DEPLOY}/outputs/ /tmp/board_images/ '
               f'&& echo PULL_OK')
        self._ssh_run(cmd)

    def _check_mmse(self):
        cmd = ("ps aux | grep -E 'convert_yolov5|run_mmse' | grep -v grep; "
               "echo '---LOG TAIL---'; "
               "tail -20 ~/mmse_all.log 2>/dev/null || echo 'No log'; "
               "echo '---RKNN FILES---'; "
               "ls -la ~/bishe/deploy/rv1126b_yolov5/model/*.rknn "
               "2>/dev/null")
        self._ssh_run(cmd)

    def _push_mmse(self):
        models = [
            "best_eiou_mmse.rknn",
            "best_baseline_mmse.rknn",
            "best_ghost_eiou_mmse.rknn",
        ]
        push_cmds = []
        for m in models:
            push_cmds.append(
                f'adb -s {ADB_SERIAL} push '
                f'~/bishe/deploy/rv1126b_yolov5/model/{m} '
                f'{BOARD_DEPLOY}/model/{m} 2>/dev/null && '
                f'echo "Pushed {m}" || echo "Skip {m} (not found)"')
        cmd = " ; ".join(push_cmds)
        self._ssh_run(cmd)

    def _check_status(self):
        def _do():
            try:
                ssh = paramiko.SSHClient()
                ssh.set_missing_host_key_policy(paramiko.AutoAddPolicy())
                ssh.connect(UBUNTU_HOST, username=UBUNTU_USER,
                            password=UBUNTU_PASS, timeout=5)
                _, out, _ = ssh.exec_command(
                    f"adb -s {ADB_SERIAL} shell "
                    f"cat /sys/class/devfreq/22000000.npu/cur_freq "
                    f"2>/dev/null", timeout=8)
                freq_raw = out.read().decode().strip()
                ssh.close()
                if freq_raw and freq_raw.isdigit():
                    freq_mhz = int(freq_raw) // 1000000
                    self.lbl_board.setText("Board: ● 在线")
                    self.lbl_board.setStyleSheet(
                        "color: #2e7d32; font-weight: bold;")
                    self.lbl_npu.setText(f"NPU: {freq_mhz} MHz")
                    self.lbl_npu.setStyleSheet("color: #2e7d32;")
                else:
                    self._status_offline()
            except Exception:
                self._status_offline()

        threading.Thread(target=_do, daemon=True).start()

    def _status_offline(self):
        self.lbl_board.setText("Board: ● 离线")
        self.lbl_board.setStyleSheet("color: #c62828;")
        self.lbl_npu.setText("NPU: —")
        self.lbl_npu.setStyleSheet("color: #999;")


# ═══════════════════════════════════════════════════════════════
# 主窗口
# ═══════════════════════════════════════════════════════════════
class MainWindow(QMainWindow):

    def __init__(self):
        super().__init__()
        self.setWindowTitle("红外多目标检测与跟踪系统 — 统一工作台")
        self.resize(1200, 800)
        self._build()
        self._apply_style()

    def _build(self):
        central = QWidget()
        layout = QVBoxLayout(central)
        layout.setContentsMargins(0, 0, 0, 0)
        layout.setSpacing(0)

        # 顶部标题
        header = QFrame()
        header.setObjectName("header")
        header.setFixedHeight(56)
        hl = QHBoxLayout(header)
        hl.setContentsMargins(24, 0, 24, 0)
        title = QLabel("红外多目标检测与跟踪系统")
        title.setObjectName("headerTitle")
        hl.addWidget(title)
        hl.addStretch()
        version = QLabel("毕业设计工作台 v2.0")
        version.setObjectName("headerVersion")
        hl.addWidget(version)
        layout.addWidget(header)

        # 标签页
        self.tabs = QTabWidget()
        self.tabs.setObjectName("mainTabs")
        self.tabs.setDocumentMode(True)
        self.tabs.addTab(DataTab(), "📁 数据处理")
        self.tabs.addTab(TrainTab(), "🔧 模型训练")
        self.tabs.addTab(DetectionTab(), "🎯 检测评估")
        self.tabs.addTab(TrackingTab(), "🔗 跟踪评估")
        self.tabs.addTab(DeployTab(), "🚀 板端部署")
        layout.addWidget(self.tabs)

        self.setCentralWidget(central)

        sb = QStatusBar()
        sb.showMessage(f"  项目根目录: {ROOT}")
        self.setStatusBar(sb)

    def _apply_style(self):
        # DPI 自适应字体
        screen = QApplication.primaryScreen()
        scale = 1.0
        if screen:
            scale = max(1.0, screen.logicalDotsPerInch() / 96.0)
        fs = int(BASE_FONT_SIZE * scale)
        fs_sm = max(12, int(fs * 0.85))
        fs_lg = int(fs * 1.2)
        fs_xl = int(fs * 1.5)

        self.setStyleSheet(f"""
            /* ── 全局 ── */
            * {{
                font-family: "Microsoft YaHei UI", "Segoe UI", sans-serif;
                font-size: {fs}px;
            }}
            QMainWindow {{
                background: #f0f2f5;
            }}

            /* ── 顶栏 ── */
            #header {{
                background: qlineargradient(
                    x1:0, y1:0, x2:1, y2:0,
                    stop:0 #1565c0, stop:1 #1976d2);
                border: none;
            }}
            #headerTitle {{
                color: #ffffff;
                font-size: {fs_xl}px;
                font-weight: 700;
                letter-spacing: 2px;
            }}
            #headerVersion {{
                color: rgba(255,255,255,0.7);
                font-size: {fs_sm}px;
            }}

            /* ── 标签栏 ── */
            #mainTabs::pane {{
                border: none;
                background: #f0f2f5;
            }}
            #mainTabs > QTabBar::tab {{
                background: #e3e7ed;
                border: none;
                padding: {int(10*scale)}px {int(28*scale)}px;
                font-size: {fs}px;
                font-weight: 600;
                color: #546e7a;
                margin: 0;
                border-bottom: 3px solid transparent;
            }}
            #mainTabs > QTabBar::tab:selected {{
                background: #f0f2f5;
                color: #1565c0;
                border-bottom: 3px solid #1565c0;
            }}
            #mainTabs > QTabBar::tab:hover:!selected {{
                background: #d5dbe3;
                color: #37474f;
            }}

            /* ── 分组框 ── */
            QGroupBox {{
                font-size: {fs}px;
                font-weight: 600;
                color: #37474f;
                border: 1px solid #d0d7de;
                border-radius: 8px;
                margin-top: 16px;
                padding: {int(20*scale)}px {int(12*scale)}px
                         {int(12*scale)}px {int(12*scale)}px;
                background: #ffffff;
            }}
            QGroupBox::title {{
                subcontrol-origin: margin;
                left: 14px;
                padding: 0 8px;
                background: #ffffff;
                color: #1565c0;
            }}

            /* ── 输入控件 ── */
            QComboBox, QLineEdit, QSpinBox, QDoubleSpinBox {{
                background: #ffffff;
                border: 1px solid #c4cdd5;
                border-radius: 6px;
                padding: {int(6*scale)}px {int(10*scale)}px;
                font-size: {fs}px;
                color: #2c3e50;
                min-height: {int(28*scale)}px;
            }}
            QComboBox:focus, QLineEdit:focus,
            QSpinBox:focus, QDoubleSpinBox:focus {{
                border-color: #1565c0;
                border-width: 2px;
            }}
            QComboBox::drop-down {{
                border: none;
                width: {int(24*scale)}px;
            }}
            QComboBox QAbstractItemView {{
                background: #ffffff;
                border: 1px solid #c4cdd5;
                selection-background-color: #e3f2fd;
                selection-color: #1565c0;
                font-size: {fs}px;
                padding: 4px;
            }}

            /* ── 标签 ── */
            QLabel {{
                font-size: {fs}px;
                color: #37474f;
            }}
            #sectionTitle {{
                font-size: {fs_lg}px;
                font-weight: 700;
                color: #1565c0;
                padding: 4px 0;
            }}

            /* ── 复选框 ── */
            QCheckBox {{
                font-size: {fs}px;
                color: #37474f;
                spacing: 8px;
            }}
            QCheckBox::indicator {{
                width: {int(18*scale)}px;
                height: {int(18*scale)}px;
            }}

            /* ── 按钮 ── */
            QPushButton {{
                background: #e8ecf0;
                border: 1px solid #c4cdd5;
                border-radius: 6px;
                padding: {int(8*scale)}px {int(18*scale)}px;
                font-size: {fs}px;
                font-weight: 500;
                color: #37474f;
            }}
            QPushButton:hover {{
                background: #dde1e6;
                border-color: #90a4ae;
            }}
            QPushButton:pressed {{
                background: #cfd8dc;
            }}
            QPushButton:disabled {{
                color: #b0bec5;
                background: #eceff1;
            }}
            #btnPrimary {{
                background: #1565c0;
                border: 1px solid #0d47a1;
                color: #ffffff;
                font-weight: 700;
                padding: {int(10*scale)}px {int(24*scale)}px;
                font-size: {fs}px;
            }}
            #btnPrimary:hover {{
                background: #1976d2;
            }}
            #btnPrimary:disabled {{
                background: #90caf9;
                border-color: #90caf9;
            }}
            #btnSecondary {{
                background: #e3f2fd;
                border: 1px solid #90caf9;
                color: #1565c0;
                font-weight: 600;
            }}
            #btnSecondary:hover {{
                background: #bbdefb;
            }}

            /* ── 指标卡片 ── */
            #metricCard {{
                background: #f5f7fa;
                border: 1px solid #d0d7de;
                border-radius: 8px;
                padding: {int(12*scale)}px;
                font-size: {fs}px;
                font-weight: 600;
                color: #37474f;
                min-width: {int(80*scale)}px;
                min-height: {int(48*scale)}px;
            }}

            /* ── 日志 ── */
            QTextEdit {{
                background: #fafbfc;
                border: 1px solid #d0d7de;
                border-radius: 6px;
                color: #2c3e50;
                font-family: "Cascadia Code", "Consolas",
                             "Courier New", monospace;
                font-size: {fs_sm}px;
                padding: 8px;
            }}

            /* ── 状态栏 ── */
            QStatusBar {{
                background: #e3e7ed;
                font-size: {fs_sm}px;
                color: #546e7a;
                border-top: 1px solid #d0d7de;
                padding: 4px;
            }}

            /* ── 滚动条 ── */
            QScrollBar:vertical {{
                background: #f0f2f5;
                width: {int(10*scale)}px;
                border: none;
                border-radius: 5px;
            }}
            QScrollBar::handle:vertical {{
                background: #b0bec5;
                border-radius: 5px;
                min-height: 30px;
            }}
            QScrollBar::handle:vertical:hover {{
                background: #90a4ae;
            }}
            QScrollBar::add-line:vertical,
            QScrollBar::sub-line:vertical {{
                height: 0px;
            }}

            /* ── 滑块 ── */
            QSlider::groove:horizontal {{
                background: #d0d7de;
                height: 6px;
                border-radius: 3px;
            }}
            QSlider::handle:horizontal {{
                background: #1565c0;
                width: {int(16*scale)}px;
                height: {int(16*scale)}px;
                margin: -{int(5*scale)}px 0;
                border-radius: {int(8*scale)}px;
            }}
            QSlider::sub-page:horizontal {{
                background: #1976d2;
                border-radius: 3px;
            }}

            /* ── 分割器 ── */
            QSplitter::handle {{
                background: #d0d7de;
                border-radius: 2px;
            }}
            QSplitter::handle:hover {{
                background: #90a4ae;
            }}
        """)


def main():
    # 高 DPI 支持
    if hasattr(Qt, 'AA_EnableHighDpiScaling'):
        QApplication.setAttribute(Qt.AA_EnableHighDpiScaling, True)
    if hasattr(Qt, 'AA_UseHighDpiPixmaps'):
        QApplication.setAttribute(Qt.AA_UseHighDpiPixmaps, True)

    app = QApplication(sys.argv)
    app.setStyle("Fusion")
    win = MainWindow()
    win.show()
    sys.exit(app.exec_())


if __name__ == "__main__":
    main()

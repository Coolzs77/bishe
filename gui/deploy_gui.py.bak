class TrainTab(QWidget):
    def __init__(self, parent=None):
        super().__init__(parent)
        self.worker = None
        self._build()

    def _build(self):
        layout = QVBoxLayout(self)
        layout.setContentsMargins(16, 16, 16, 16)
        layout.setSpacing(12)

        # ── 单模型训练 ──
        g1 = QGroupBox("单模型训练 (train_yolov5.py)")
        gl1 = QGridLayout()
        gl1.setSpacing(10)
        gl1.addWidget(QLabel("配置文件:"), 0, 0)
        self.train_config = QLineEdit("configs/train_config.yaml")
        gl1.addWidget(self.train_config, 0, 1, 1, 2)
        gl1.addWidget(QLabel("Epochs:"), 1, 0)
        self.epochs_spin = QSpinBox()
        self.epochs_spin.setRange(1, 1000)
        self.epochs_spin.setValue(100)
        gl1.addWidget(self.epochs_spin, 1, 1, 1, 2)
        gl1.addWidget(QLabel("Batch:"), 2, 0)
        self.batch_spin = QSpinBox()
        self.batch_spin.setRange(1, 128)
        self.batch_spin.setValue(16)
        gl1.addWidget(self.batch_spin, 2, 1, 1, 2)
        gl1.addWidget(QLabel("图像尺寸:"), 3, 0)
        self.imgsz_spin = QSpinBox()
        self.imgsz_spin.setRange(320, 1280)
        self.imgsz_spin.setValue(640)
        self.imgsz_spin.setSingleStep(32)
        gl1.addWidget(self.imgsz_spin, 3, 1, 1, 2)
        self.btn_train = QPushButton("▶ 开始训练")
        self.btn_train.setObjectName("btnPrimary")
        self.btn_train.clicked.connect(self._run_train)
        gl1.addWidget(self.btn_train, 4, 0, 1, 3)
        g1.setLayout(gl1)
        layout.addWidget(g1)

        # ── 消融训练 ──
        g2 = QGroupBox("消融实验 (train_ablation.py)")
        gl2 = QGridLayout()
        gl2.setSpacing(10)
        gl2.addWidget(QLabel("Profile:"), 0, 0)
        self.profile_combo = QComboBox()
        self.profile_combo.addItem("controlled — 严格控变量", "controlled")
        self.profile_combo.addItem("optimal — 独立最优参数", "optimal")
        gl2.addWidget(self.profile_combo, 0, 1, 1, 2)
        gl2.addWidget(QLabel("仅运行:"), 1, 0)
        self.only_edit = QLineEdit()
        self.only_edit.setPlaceholderText("留空=全部 或 exp7")
        gl2.addWidget(self.only_edit, 1, 1, 1, 2)
        self.btn_ablation = QPushButton("▶ 开始消融训练")
        self.btn_ablation.setObjectName("btnPrimary")
        self.btn_ablation.clicked.connect(self._run_ablation)
        gl2.addWidget(self.btn_ablation, 2, 0, 1, 3)
        g2.setLayout(gl2)
        layout.addWidget(g2)

        self.log = LogPanel()
        layout.addWidget(self.log, stretch=1)

    def _run_cmd(self, cmd, btn):
        if self.worker and self.worker.isRunning():
            QMessageBox.warning(self, "忙", "上一个任务仍在运行")
            return
        self.log.clear_log()
        btn.setEnabled(False)
        self.worker = LocalCmdWorker(cmd)
        self.worker.log_line.connect(self.log.append_log)
        self.worker.finished.connect(lambda _: btn.setEnabled(True))
        self.worker.start()

    def _run_train(self):
        cmd = (f'python scripts/train/train_yolov5.py '
               f'--config "{self.train_config.text()}" '
               f'--epochs {self.epochs_spin.value()} '
               f'--batch-size {self.batch_spin.value()} '
               f'--img-size {self.imgsz_spin.value()}')
        self._run_cmd(cmd, self.btn_train)

    def _run_ablation(self):
        profile = self.profile_combo.currentData()
        cmd = f'python scripts/train/train_ablation.py --profile {profile}'
        only = self.only_edit.text().strip()
        if only:
            cmd += f' --only {only}'
        self._run_cmd(cmd, self.btn_ablation)


